{
  "name": "@opslane/verify",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "bin": {
    "verify": "dist/cli.js"
  },
  "files": [
    "dist/",
    "src/prompts/"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "cp -r src/prompts dist/prompts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
